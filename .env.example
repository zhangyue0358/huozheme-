# Supabase Project Settings > API
# Do not commit your real .env file.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: development-only test account password.
# Create test-a@huozhema.local and test-b@huozhema.local in Supabase Auth with this password.
# Test buttons show only when this value is set and either development mode is running
# or EXPO_PUBLIC_ENABLE_TEST_ACCOUNTS=true.
EXPO_PUBLIC_DEV_TEST_PASSWORD=HuozhemaTest2026!

# Optional: enable test account buttons in internal preview builds.
# Keep this false or unset for production builds, and do not define
# EXPO_PUBLIC_DEV_TEST_PASSWORD in the EAS production profile.
EXPO_PUBLIC_ENABLE_TEST_ACCOUNTS=false

# Optional: mailbox opened by the in-app account deletion request.
EXPO_PUBLIC_ACCOUNT_DELETION_EMAIL=senbeikeji@senbeikeji.cn

# Server-only admin scripts. Never use this in app code, never prefix it with EXPO_PUBLIC_,
# and never commit a real service role key.
# SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
